# ─── Vercel API project (root) ───
# Set these in Vercel → Project → Settings → Environment Variables

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Dev only (local SSL issues):
# ANTHROPIC_INSECURE_SSL=true

BRIGHTDATA_API_TOKEN=

# Firebase — paste minified JSON (one line) on Vercel; file path only works locally
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Vercel frontend project (frontend/) ───
# VITE_MAPTILER_KEY=
# VITE_API_BASE_URL=   (leave empty — frontend vercel.json proxies /api to API project)

# Local dev
PORT=3001
